{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "name": "uw-huis-werkt-voor-u",
  "rewrites": [
    {
      "source": "/algemene-voorwaarden.html",
      "destination": "/algemene-voorwaarden.html"
    },
    {
      "source": "/algemene-voorwaarden.docx",
      "destination": "/algemene-voorwaarden.docx"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
